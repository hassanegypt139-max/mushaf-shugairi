/* ===== Global Styles ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}

:root {
    --primary: #0F4C3A;
    --primary-light: #1a6b54;
    --primary-dark: #0a3a2c;
    --gold: #D4AF37;
    --gold-light: #f0d878;
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-500: #6b7280;
    --gray-700: #374151;
    --gray-900: #111827;
    --success: #10b981;
    --danger: #ef4444;
    --shadow-sm: 0 1px 2px 0 rgba(0,0,0,.05);
    --shadow: 0 4px 6px -1px rgba(0,0,0,.1);
    --shadow-lg: 0 10px 25px -5px rgba(0,0,0,.1);
    --radius: 12px;
    --radius-lg: 20px;
}

body {
    font-family: 'Cairo', 'Tajawal', sans-serif;
    background: var(--gray-50);
    color: var(--gray-900);
    min-height: 100vh;
    line-height: 1.6;
    direction: rtl;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
}

/* ===== Header ===== */
.header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    color: white;
    padding: 1rem 0;
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    justify-content: center;
}

.logo-icon {
    font-size: 2rem;
}

.logo h1 {
    font-size: 1.5rem;
    font-weight: 700;
}

.nav {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0.5rem 0;
    scrollbar-width: none;
}

.nav::-webkit-scrollbar {
    display: none;
}

.nav-btn {
    background: rgba(255,255,255,0.1);
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
}

.nav-btn:hover {
    background: rgba(255,255,255,0.2);
}

.nav-btn.active {
    background: var(--gold);
    color: var(--primary-dark);
}

/* ===== Main ===== */
.main {
    padding: 2rem 0;
    min-height: calc(100vh - 150px);
}

.section {
    display: none;
    animation: fadeIn 0.5s ease;
}

.section.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ===== Hero ===== */
.hero {
    text-align: center;
    padding: 2rem 1rem;
    margin-bottom: 2rem;
}

.hero h2 {
    color: var(--primary);
    font-size: 2rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
}

.hero p {
    color: var(--gray-500);
    font-size: 1.1rem;
}

/* ===== Features ===== */
.features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.feature-card {
    background: white;
    padding: 2rem 1.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: var(--shadow);
    border: 2px solid transparent;
}

.feature-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--gold);
}

.feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
}

.feature-card h3 {
    color: var(--primary);
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
}

.feature-card p {
    color: var(--gray-500);
    font-size: 0.95rem;
}

/* ===== Section Header ===== */
.section-header {
    margin-bottom: 1.5rem;
}

.section-header h2 {
    color: var(--primary);
    font-size: 1.75rem;
    margin-bottom: 1rem;
}

.search-box input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--gray-200);
    border-radius: var(--radius);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.3s;
}

.search-box input:focus {
    outline: none;
    border-color: var(--primary);
}

/* ===== Surah Grid ===== */
.surah-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
}

.surah-card {
    background: white;
    padding: 1.25rem;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
}

.surah-card:hover {
    transform: translateX(-5px);
    box-shadow: var(--shadow);
    border-color: var(--primary);
}

.surah-number {
    background: var(--primary);
    color: white;
    width: 45px;
    height: 45px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
}

.surah-info {
    flex: 1;
}

.surah-name-ar {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.25rem;
}

.surah-name-en {
    font-size: 0.85rem;
    color: var(--gray-500);
}

.surah-meta {
    text-align: left;
    color: var(--gray-500);
    font-size: 0.85rem;
}

.surah-meta .type {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background: var(--gray-100);
    border-radius: 4px;
    font-size: 0.75rem;
    margin-top: 0.25rem;
}

/* ===== Surah Detail ===== */
.back-btn {
    background: var(--primary);
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    font-family: inherit;
    font-size: 1rem;
    cursor: pointer;
    margin-bottom: 1rem;
    transition: all 0.3s;
}

.back-btn:hover {
    background: var(--primary-dark);
}

.surah-header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    color: white;
    padding: 2rem;
    border-radius: var(--radius-lg);
    text-align: center;
    margin-bottom: 1.5rem;
}

.surah-header h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

.surah-header p {
    opacity: 0.9;
}

.ayah-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.ayah-card {
    background: white;
    padding: 1.5rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border-right: 4px solid var(--gold);
}

.ayah-text {
    font-family: 'Amiri', serif;
    font-size: 1.75rem;
    line-height: 2.2;
    color: var(--gray-900);
    text-align: right;
    margin-bottom: 1rem;
    font-weight: 400;
}

.ayah-number {
    display: inline-block;
    background: var(--gold);
    color: var(--primary-dark);
    width: 35px;
    height: 35px;
    border-radius: 50%;
    text-align: center;
    line-height: 35px;
    font-weight: 700;
    font-size: 0.9rem;
    margin: 0 0.5rem;
}

.ayah-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--gray-200);
}

.action-btn {
    background: var(--gray-100);
    border: none;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.85rem;
    color: var(--gray-700);
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
}

.action-btn:hover {
    background: var(--primary);
    color: white;
}

.action-btn.active {
    background: var(--gold);
    color: var(--primary-dark);
}

/* ===== Adhkar ===== */
.adhkar-categories {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}

.category-card {
    background: white;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: var(--shadow);
    border: 2px solid transparent;
}

.category-card:hover {
    transform: translateY(-5px);
    border-color: var(--gold);
}

.category-icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.category-card h3 {
    color: var(--primary);
}

.adhkar-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.dhikr-card {
    background: white;
    padding: 1.5rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border-right: 4px solid var(--primary);
}

.dhikr-text {
    font-family: 'Amiri', serif;
    font-size: 1.5rem;
    line-height: 2;
    color: var(--gray-900);
    text-align: right;
    margin-bottom: 0.75rem;
}

.dhikr-translation {
    color: var(--gray-500);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--gray-200);
}

.dhikr-source {
    background: var(--gold);
    color: var(--primary-dark);
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.85rem;
    display: inline-block;
    margin-top: 0.5rem;
}

.dhikr-counter {
    background: var(--primary);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    margin-top: 0.75rem;
    display: inline-block;
}

/* ===== Audio Player ===== */
.audio-player {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.2);
    z-index: 1000;
}

.player-info {
    flex: 1;
}

.player-title {
    font-weight: 700;
    margin-bottom: 0.25rem;
}

.player-subtitle {
    font-size: 0.85rem;
    opacity: 0.8;
}

.player-controls {
    display: flex;
    gap: 0.5rem;
}

.player-btn {
    background: var(--gold);
    color: var(--primary-dark);
    border: none;
    width: 45px;
    height: 45px;
    border-radius: 50%;
    font-size: 1.25rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
}

.player-btn:hover {
    background: var(--gold-light);
    transform: scale(1.1);
}

/* ===== Install Button ===== */
.install-btn {
    position: fixed;
    bottom: 90px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--primary-dark);
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 30px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
    z-index: 999;
    transition: all 0.3s;
}

.install-btn:hover {
    background: var(--gold-light);
    transform: translateX(-50%) scale(1.05);
}

/* ===== Favorites ===== */
.empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--gray-500);
}

.empty-state .icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

/* ===== Loading ===== */
.loading {
    text-align: center;
    padding: 2rem;
    color: var(--gray-500);
}

.spinner {
    border: 3px solid var(--gray-200);
    border-top: 3px solid var(--primary);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 1s linear infinite;
    margin: 0 auto 1rem;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ===== Toast Notification ===== */
.toast {
    position: fixed;
    top: 80px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    z-index: 2000;
    animation: slideDown 0.3s ease;
}

@keyframes slideDown {
    from { transform: translate(-50%, -100%); }
    to { transform: translate(-50%, 0); }
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
    .logo h1 {
        font-size: 1.25rem;
    }
    
    .hero h2 {
        font-size: 1.5rem;
    }
    
    .ayah-text {
        font-size: 1.4rem;
    }
    
    .features {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .nav-btn {
        font-size: 0.85rem;
        padding: 0.4rem 0.8rem;
    }
    
    .surah-header {
        padding: 1.5rem 1rem;
    }
    
    .surah-header h2 {
        font-size: 1.5rem;
    }
}